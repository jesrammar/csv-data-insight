IMAGE_OWNER=local

# --- Database (required) ---
POSTGRES_USER=enterpriseiq
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
POSTGRES_DB=enterpriseiq
POSTGRES_PORT=5433

# --- Backend (required) ---
# Use a long random secret (at least 32+ chars). Rotating this invalidates sessions.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
BACKEND_PORT=8081

# If SPA and API are served from the same origin via nginx (/api), leave empty.
# If you call the API from another origin, set a comma-separated allowlist.
# Example: CORS_ALLOWED_ORIGINS=https://app.tudominio.com,https://admin.tudominio.com
CORS_ALLOWED_ORIGINS=

# Cookies
APP_COOKIES_SECURE=true
APP_COOKIES_SAME_SITE=Strict

# --- Observability (required if you use Grafana) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Optional ports (already bound to localhost in compose)
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000

